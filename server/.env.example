# Server Port
PORT=5000

# MongoDB Connection
MONGO_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/stockverse

# JWT Authentication
JWT_SECRET=your_jwt_secret_key_here

# APIs
FINNHUB_API_KEY=your_finnhub_api_key
ALPHA_VANTAGE_KEY=your_alpha_vantage_key
GEMINI_API_KEY=your_gemini_api_key
# Optional: force a model if the built-in fallback list does not fit your quota/region
# GEMINI_MODEL=gemini-2.5-flash
NEWS_API_KEY=your_news_api_key

# The .env file should NOT be committed to git - copy this to .env and fill in your actual values
