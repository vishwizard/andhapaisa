# Copy to .env.local for local overrides (optional).
# Production: set this in your host’s build env (Vercel/Netlify/etc.).

# Full API base URL including /api path, e.g. https://your-server.onrender.com/api
# Leave unset locally to use Vite dev proxy (/api → localhost:5000).
# VITE_API_URL=https://your-backend.example.com/api
